# 浮游作品集 API — 环境变量（在 Vercel 项目 Settings → Environment Variables 中配置）

# GitHub Personal Access Token（需 repo 写入权限）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# 仓库（默认 Shigurekaya/shigure-web）
GITHUB_REPO=Shigurekaya/shigure-web

# 分支（默认 main）
GITHUB_BRANCH=main

# 管理接口密钥（自行设置强密码，上传/删除时携带）
FUYUU_ADMIN_TOKEN=your-secret-token-here
